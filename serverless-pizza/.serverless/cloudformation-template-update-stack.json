        "Ref": "SendOrderLambdaVersionAvWt9ElhIlIOVVr3SsjZ8vqu8BFWrtJTAQ0bQoHjBR4"
      },
      "Export": {
        "Name": "sls-pizzaApp-dev-SendOrderLambdaFunctionQualifiedArn"
      }
    },
    "HttpApiId": {
